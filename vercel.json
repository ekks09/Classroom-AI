{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/main.py"
    },
    {
      "src": "/student",
      "dest": "/static/student.html"
    },
    {
      "src": "/teacher",
      "dest": "/static/teacher.html"
    },
    {
      "src": "/",
      "dest": "/static/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/static/$1"
    }
  ],
  "functions": {
    "main.py": {
      "runtime": "python3.11"
    }
  },
  "env": {
    "PYTHONPATH": "."
  }
}