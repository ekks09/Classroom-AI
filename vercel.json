{
  "version": 2,
  "routes": [
    { "src": "/student", "dest": "/static/student.html" },
    { "src": "/teacher", "dest": "/static/teacher.html" },
    { "src": "/", "dest": "/static/index.html" },
    { 
      "src": "/static/(.*)", 
      "dest": "/static/$1" 
    },
    { 
      "src": "/(.*)", 
      "dest": "/static/$1" 
    }
  ]
}
