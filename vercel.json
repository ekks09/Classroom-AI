{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/static/index.html" },
    { "source": "/student", "destination": "/static/student.html" },
    { "source": "/teacher", "destination": "/static/teacher.html" },
    { "source": "/:path*", "destination": "/static/:path*" }
  ]
}
